{
  "name": "docker",
  "description": "A self-sufficient runtime for containers",
  "options": [
    {
      "name": "--version",
      "description": "Print version information and quit"
    },
    {
      "name": "--help",
      "description": "Print usage"
    },
    {
      "name": ["-H", "--host"],
      "description": "Daemon socket to connect to",
      "args": {
        "name": "host"
      }
    },
    {
      "name": ["-D", "--debug"],
      "description": "Enable debug mode"
    },
    {
      "name": "--context",
      "description": "Name of the context to use to connect to the daemon",
      "args": {
        "name": "name"
      }
    }
  ],
  "subcommands": [
    {
      "name": "build",
      "description": "Build an image from a Dockerfile",
      "options": [
        {
          "name": ["-t", "--tag"],
          "description": "Name and optionally a tag in the name:tag format",
          "args": {
            "name": "name:tag"
          },
          "isRepeatable": true
        },
        {
          "name": ["-f", "--file"],
          "description": "Name of the Dockerfile",
          "args": {
            "name": "dockerfile",
            "template": "filepaths"
          }
        },
        {
          "name": "--no-cache",
          "description": "Do not use cache when building the image"
        },
        {
          "name": "--pull",
          "description": "Always attempt to pull a newer version of the image"
        },
        {
          "name": "--build-arg",
          "description": "Set build-time variables",
          "args": {
            "name": "key=value"
          },
          "isRepeatable": true
        },
        {
          "name": "--target",
          "description": "Set the target build stage to build",
          "args": {
            "name": "stage"
          }
        },
        {
          "name": "--platform",
          "description": "Set platform if server is multi-platform capable",
          "args": {
            "name": "platform"
          }
        },
        {
          "name": "--progress",
          "description": "Set type of progress output",
          "args": {
            "name": "type",
            "suggestions": ["auto", "plain", "tty"]
          }
        },
        {
          "name": ["-q", "--quiet"],
          "description": "Suppress the build output and print image ID on success"
        },
        {
          "name": "--rm",
          "description": "Remove intermediate containers after a successful build"
        },
        {
          "name": "--network",
          "description": "Set the networking mode for the RUN instructions during build",
          "args": {
            "name": "network"
          }
        },
        {
          "name": "--label",
          "description": "Set metadata for an image",
          "args": {
            "name": "key=value"
          },
          "isRepeatable": true
        }
      ],
      "args": {
        "name": "path",
        "template": "folders"
      }
    },
    {
      "name": "run",
      "description": "Create and run a new container from an image",
      "options": [
        {
          "name": ["-d", "--detach"],
          "description": "Run container in background and print container ID"
        },
        {
          "name": ["-i", "--interactive"],
          "description": "Keep STDIN open even if not attached"
        },
        {
          "name": ["-t", "--tty"],
          "description": "Allocate a pseudo-TTY"
        },
        {
          "name": "--name",
          "description": "Assign a name to the container",
          "args": {
            "name": "name"
          }
        },
        {
          "name": ["-p", "--publish"],
          "description": "Publish a container port to the host",
          "args": {
            "name": "hostPort:containerPort"
          },
          "isRepeatable": true
        },
        {
          "name": ["-v", "--volume"],
          "description": "Bind mount a volume",
          "args": {
            "name": "host-src:container-dest"
          },
          "isRepeatable": true
        },
        {
          "name": "--rm",
          "description": "Automatically remove the container when it exits"
        },
        {
          "name": ["-e", "--env"],
          "description": "Set environment variables",
          "args": {
            "name": "key=value"
          },
          "isRepeatable": true
        },
        {
          "name": "--env-file",
          "description": "Read in a file of environment variables",
          "args": {
            "name": "file",
            "template": "filepaths"
          }
        },
        {
          "name": ["-w", "--workdir"],
          "description": "Working directory inside the container",
          "args": {
            "name": "dir"
          }
        },
        {
          "name": "--network",
          "description": "Connect a container to a network",
          "args": {
            "name": "network"
          }
        },
        {
          "name": "--restart",
          "description": "Restart policy to apply when a container exits",
          "args": {
            "name": "policy",
            "suggestions": ["no", "on-failure", "always", "unless-stopped"]
          }
        },
        {
          "name": "--platform",
          "description": "Set platform if server is multi-platform capable",
          "args": {
            "name": "platform"
          }
        },
        {
          "name": "--entrypoint",
          "description": "Overwrite the default ENTRYPOINT of the image",
          "args": {
            "name": "entrypoint"
          }
        },
        {
          "name": ["-u", "--user"],
          "description": "Username or UID",
          "args": {
            "name": "user"
          }
        },
        {
          "name": "--cpus",
          "description": "Number of CPUs",
          "args": {
            "name": "decimal"
          }
        },
        {
          "name": ["-m", "--memory"],
          "description": "Memory limit",
          "args": {
            "name": "bytes"
          }
        },
        {
          "name": "--privileged",
          "description": "Give extended privileges to this container"
        },
        {
          "name": "--label",
          "description": "Set metadata on a container",
          "args": {
            "name": "key=value"
          },
          "isRepeatable": true
        }
      ],
      "args": {
        "name": "image"
      }
    },
    {
      "name": "exec",
      "description": "Execute a command in a running container",
      "options": [
        {
          "name": ["-i", "--interactive"],
          "description": "Keep STDIN open even if not attached"
        },
        {
          "name": ["-t", "--tty"],
          "description": "Allocate a pseudo-TTY"
        },
        {
          "name": ["-d", "--detach"],
          "description": "Run command in the background"
        },
        {
          "name": ["-e", "--env"],
          "description": "Set environment variables",
          "args": {
            "name": "key=value"
          },
          "isRepeatable": true
        },
        {
          "name": ["-u", "--user"],
          "description": "Username or UID",
          "args": {
            "name": "user"
          }
        },
        {
          "name": ["-w", "--workdir"],
          "description": "Working directory inside the container",
          "args": {
            "name": "dir"
          }
        },
        {
          "name": "--privileged",
          "description": "Give extended privileges to the command"
        }
      ],
      "args": [
        {
          "name": "container"
        },
        {
          "name": "command",
          "isVariadic": true
        }
      ]
    },
    {
      "name": "ps",
      "description": "List containers",
      "options": [
        {
          "name": ["-a", "--all"],
          "description": "Show all containers (default shows just running)"
        },
        {
          "name": ["-q", "--quiet"],
          "description": "Only display container IDs"
        },
        {
          "name": ["-s", "--size"],
          "description": "Display total file sizes"
        },
        {
          "name": ["-n", "--last"],
          "description": "Show n last created containers",
          "args": {
            "name": "n"
          }
        },
        {
          "name": ["-f", "--filter"],
          "description": "Filter output based on conditions provided",
          "args": {
            "name": "filter"
          }
        },
        {
          "name": "--format",
          "description": "Format the output using a Go template",
          "args": {
            "name": "format"
          }
        },
        {
          "name": "--no-trunc",
          "description": "Don't truncate output"
        }
      ]
    },
    {
      "name": "images",
      "description": "List images",
      "options": [
        {
          "name": ["-a", "--all"],
          "description": "Show all images (default hides intermediate images)"
        },
        {
          "name": ["-q", "--quiet"],
          "description": "Only show image IDs"
        },
        {
          "name": ["-f", "--filter"],
          "description": "Filter output based on conditions provided",
          "args": {
            "name": "filter"
          }
        },
        {
          "name": "--format",
          "description": "Format the output using a Go template",
          "args": {
            "name": "format"
          }
        },
        {
          "name": "--no-trunc",
          "description": "Don't truncate output"
        },
        {
          "name": "--digests",
          "description": "Show digests"
        }
      ],
      "args": {
        "name": "repository",
        "isOptional": true
      }
    },
    {
      "name": "pull",
      "description": "Download an image from a registry",
      "options": [
        {
          "name": ["-a", "--all-tags"],
          "description": "Download all tagged images in the repository"
        },
        {
          "name": "--platform",
          "description": "Set platform if server is multi-platform capable",
          "args": {
            "name": "platform"
          }
        },
        {
          "name": ["-q", "--quiet"],
          "description": "Suppress verbose output"
        },
        {
          "name": "--disable-content-trust",
          "description": "Skip image verification"
        }
      ],
      "args": {
        "name": "name:tag"
      }
    },
    {
      "name": "push",
      "description": "Upload an image to a registry",
      "options": [
        {
          "name": ["-a", "--all-tags"],
          "description": "Push all tags of the specified image"
        },
        {
          "name": ["-q", "--quiet"],
          "description": "Suppress verbose output"
        },
        {
          "name": "--disable-content-trust",
          "description": "Skip image signing"
        }
      ],
      "args": {
        "name": "name:tag"
      }
    },
    {
      "name": "rm",
      "description": "Remove one or more containers",
      "options": [
        {
          "name": ["-f", "--force"],
          "description": "Force the removal of a running container"
        },
        {
          "name": ["-v", "--volumes"],
          "description": "Remove anonymous volumes associated with the container"
        },
        {
          "name": ["-l", "--link"],
          "description": "Remove the specified link"
        }
      ],
      "args": {
        "name": "container",
        "isVariadic": true
      }
    },
    {
      "name": "rmi",
      "description": "Remove one or more images",
      "options": [
        {
          "name": ["-f", "--force"],
          "description": "Force removal of the image"
        },
        {
          "name": "--no-prune",
          "description": "Do not delete untagged parents"
        }
      ],
      "args": {
        "name": "image",
        "isVariadic": true
      }
    },
    {
      "name": "logs",
      "description": "Fetch the logs of a container",
      "options": [
        {
          "name": ["-f", "--follow"],
          "description": "Follow log output"
        },
        {
          "name": "--tail",
          "description": "Number of lines to show from the end of the logs",
          "args": {
            "name": "lines"
          }
        },
        {
          "name": ["-t", "--timestamps"],
          "description": "Show timestamps"
        },
        {
          "name": "--since",
          "description": "Show logs since timestamp or relative time",
          "args": {
            "name": "time"
          }
        },
        {
          "name": "--until",
          "description": "Show logs before a timestamp or relative time",
          "args": {
            "name": "time"
          }
        },
        {
          "name": "--details",
          "description": "Show extra details provided to logs"
        }
      ],
      "args": {
        "name": "container"
      }
    },
    {
      "name": "stop",
      "description": "Stop one or more running containers",
      "options": [
        {
          "name": ["-t", "--time"],
          "description": "Seconds to wait before killing the container",
          "args": {
            "name": "seconds"
          }
        },
        {
          "name": ["-s", "--signal"],
          "description": "Signal to send to the container",
          "args": {
            "name": "signal"
          }
        }
      ],
      "args": {
        "name": "container",
        "isVariadic": true
      }
    },
    {
      "name": "start",
      "description": "Start one or more stopped containers",
      "options": [
        {
          "name": ["-a", "--attach"],
          "description": "Attach STDOUT/STDERR and forward signals"
        },
        {
          "name": ["-i", "--interactive"],
          "description": "Attach container's STDIN"
        }
      ],
      "args": {
        "name": "container",
        "isVariadic": true
      }
    },
    {
      "name": "restart",
      "description": "Restart one or more containers",
      "options": [
        {
          "name": ["-t", "--time"],
          "description": "Seconds to wait before killing the container",
          "args": {
            "name": "seconds"
          }
        },
        {
          "name": ["-s", "--signal"],
          "description": "Signal to send to the container",
          "args": {
            "name": "signal"
          }
        }
      ],
      "args": {
        "name": "container",
        "isVariadic": true
      }
    },
    {
      "name": "compose",
      "description": "Define and run multi-container applications with Docker Compose",
      "options": [
        {
          "name": ["-f", "--file"],
          "description": "Compose configuration files",
          "args": {
            "name": "file",
            "template": "filepaths"
          },
          "isRepeatable": true
        },
        {
          "name": "--project-name",
          "description": "Project name",
          "args": {
            "name": "name"
          }
        },
        {
          "name": "--profile",
          "description": "Specify a profile to enable",
          "args": {
            "name": "profile"
          },
          "isRepeatable": true
        },
        {
          "name": "--env-file",
          "description": "Specify an alternate environment file",
          "args": {
            "name": "path",
            "template": "filepaths"
          }
        }
      ],
      "subcommands": [
        {
          "name": "up",
          "description": "Create and start containers",
          "options": [
            {
              "name": ["-d", "--detach"],
              "description": "Detached mode: run containers in the background"
            },
            {
              "name": "--build",
              "description": "Build images before starting containers"
            },
            {
              "name": "--force-recreate",
              "description": "Recreate containers even if configuration has not changed"
            },
            {
              "name": "--no-build",
              "description": "Do not build an image even if it is missing"
            },
            {
              "name": "--no-deps",
              "description": "Do not start linked services"
            },
            {
              "name": "--no-recreate",
              "description": "Do not recreate containers if they already exist"
            },
            {
              "name": "--remove-orphans",
              "description": "Remove containers for services not defined in the Compose file"
            },
            {
              "name": "--scale",
              "description": "Scale SERVICE to NUM instances",
              "args": {
                "name": "service=num"
              },
              "isRepeatable": true
            },
            {
              "name": "--wait",
              "description": "Wait for services to be running or healthy"
            },
            {
              "name": "--pull",
              "description": "Pull image before running",
              "args": {
                "name": "policy",
                "suggestions": ["always", "missing", "never"]
              }
            }
          ],
          "args": {
            "name": "service",
            "isVariadic": true,
            "isOptional": true
          }
        },
        {
          "name": "down",
          "description": "Stop and remove containers, networks",
          "options": [
            {
              "name": "--rmi",
              "description": "Remove images used by services",
              "args": {
                "name": "type",
                "suggestions": ["all", "local"]
              }
            },
            {
              "name": ["-v", "--volumes"],
              "description": "Remove named volumes declared in the volumes section"
            },
            {
              "name": "--remove-orphans",
              "description": "Remove containers for services not defined in the Compose file"
            },
            {
              "name": ["-t", "--timeout"],
              "description": "Specify a shutdown timeout in seconds",
              "args": {
                "name": "seconds"
              }
            }
          ]
        },
        {
          "name": "build",
          "description": "Build or rebuild services",
          "options": [
            {
              "name": "--no-cache",
              "description": "Do not use cache when building the image"
            },
            {
              "name": "--pull",
              "description": "Always attempt to pull a newer version of the image"
            },
            {
              "name": "--build-arg",
              "description": "Set build-time variables for services",
              "args": {
                "name": "key=value"
              },
              "isRepeatable": true
            },
            {
              "name": "--progress",
              "description": "Set type of progress output",
              "args": {
                "name": "type",
                "suggestions": ["auto", "plain", "tty"]
              }
            }
          ],
          "args": {
            "name": "service",
            "isVariadic": true,
            "isOptional": true
          }
        },
        {
          "name": "logs",
          "description": "View output from containers",
          "options": [
            {
              "name": ["-f", "--follow"],
              "description": "Follow log output"
            },
            {
              "name": "--tail",
              "description": "Number of lines to show from the end of the logs",
              "args": {
                "name": "lines"
              }
            },
            {
              "name": ["-t", "--timestamps"],
              "description": "Show timestamps"
            },
            {
              "name": "--no-color",
              "description": "Produce monochrome output"
            },
            {
              "name": "--since",
              "description": "Show logs since timestamp or relative time",
              "args": {
                "name": "time"
              }
            }
          ],
          "args": {
            "name": "service",
            "isVariadic": true,
            "isOptional": true
          }
        },
        {
          "name": "ps",
          "description": "List containers",
          "options": [
            {
              "name": ["-a", "--all"],
              "description": "Show all stopped containers"
            },
            {
              "name": ["-q", "--quiet"],
              "description": "Only display IDs"
            },
            {
              "name": "--format",
              "description": "Format the output",
              "args": {
                "name": "format",
                "suggestions": ["table", "json"]
              }
            },
            {
              "name": "--status",
              "description": "Filter services by status",
              "args": {
                "name": "status",
                "suggestions": ["paused", "restarting", "removing", "running", "dead", "created", "exited"]
              }
            }
          ],
          "args": {
            "name": "service",
            "isVariadic": true,
            "isOptional": true
          }
        }
      ]
    }
  ]
}
